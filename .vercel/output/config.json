{
  "version": 3,
  "routes": [
    {
      "handle": "filesystem"
    },
    {
      "src": "^/tools/?$",
      "dest": "/tools/index.html"
    },
    {
      "src": "^/gcse-maths-grade-boundaries/?$",
      "dest": "/gcse-maths-grade-boundaries/index.html"
    },
    {
      "src": "^/free-tools/?$",
      "dest": "/tools/index.html"
    },
    {
      "src": "^/free-tools/gcse-maths-topic-weakness-test/?$",
      "dest": "/index.html"
    },
    {
      "src": "^/free-tools/gcse-maths-grade-target-planner/?$",
      "dest": "/index.html"
    },
    {
      "src": "^/(.*)$",
      "dest": "/index.html"
    },
    {
      "handle": "error"
    },
    {
      "status": 404,
      "src": "^(?!/api).*$",
      "dest": "/404.html"
    }
  ],
  "framework": {
    "version": "7.3.0"
  },
  "crons": []
}
