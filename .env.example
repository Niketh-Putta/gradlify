# Stripe configuration
ENVIRONMENT="development"
STRIPE_SECRET_KEY_TEST=""
STRIPE_SECRET_KEY_LIVE=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET_TEST=""
STRIPE_WEBHOOK_SECRET_LIVE=""
STRIPE_PRICE_MONTHLY_TEST=""
STRIPE_PRICE_MONTHLY_LIVE=""
STRIPE_PRICE_ANNUAL_TEST=""
STRIPE_PRICE_ANNUAL_LIVE=""
STRIPE_PRICE_11PLUS_MONTHLY_TEST=""
STRIPE_PRICE_11PLUS_ANNUAL_TEST=""
STRIPE_PRICE_11PLUS_MONTHLY_LIVE=""
STRIPE_PRICE_11PLUS_ANNUAL_LIVE=""

# Application URLs for success/cancel redirects
# Point this at your local origin when running `npm run dev`; production overrides should be stored elsewhere.
APP_BASE_URL="http://127.0.0.1:5173"
